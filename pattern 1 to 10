 import java.util.*;
public class Main {
    public static void main(String[] args){
        Scanner sc = new Scanner(System.in);
        int n=sc.nextInt();
        int num=10;

        for(int i=1;i<=n;i++){//row
            for(int j=1;j<=i;j++){//c
                System.out.print(num + " ");
                num++;
            }
            System.out.println();
        }


    }
}
